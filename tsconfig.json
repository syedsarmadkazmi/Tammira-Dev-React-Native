{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "~app/screens": ["src/screens"],
      "~app/components": ["src/components"],
      "~app/collections": ["src/collections"],
      "~app/services": ["src/services"],
      "~app/store": ["src/store"]
    }
  },
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js",
    "node_modules"
  ],
  "include": ["**/*.ts", "**/*.tsx", "jest.setup.js"]
}
